{
  "name": "chatly",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w chatly-web",
    "dev:native": "npm run start -w chatly-native",
    "test:web": "npm test -w chatly-web",
    "e2e:web": "npm run e2e -w chatly-web",
    "test:native": "npm test -w chatly-native",
    "e2e:native": "npm run e2e -w chatly-native",
    "format": "prettier . --write",
    "format:ci": "prettier . --check",
    "lint:web": "npm run lint:fix -w chatly-web",
    "lint:web:ci": "npm run lint -w chatly-web",
    "lint:native": "npm run lint:fix -w chatly-native",
    "lint:native:ci": "npm run lint -w chatly-native",
    "build:native": "npm run build -w chatly-native",
    "preview:native": "npm run preview -w chatly-native"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0"
  },
  "overrides": {
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "react-native-svg": "15.12.1"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "react-hook-form": "^7.74.0",
    "zod": "^4.4.2"
  }
}
