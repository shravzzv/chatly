{
  "name": "chatly",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev -w chatly-web",
    "dev:native": "npm run start -w chatly-native",
    "test:web": "npm test -w chatly-web",
    "test:web:e2e": "npm run test:e2e -w chatly-web",
    "format": "prettier . --write",
    "format:ci": "prettier . --check",
    "lint:web": "npm run lint:fix -w chatly-web",
    "lint:web:ci": "npm run lint -w chatly-web",
    "lint:native": "npm run lint:fix -w chatly-native",
    "lint:native:ci": "npm run lint -w chatly-native"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "@types/react": "19.1.17",
    "@types/react-dom": "19.1.7"
  },
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "19.1.17",
    "@types/react-dom": "19.1.7"
  }
}
