{
  "deno.enablePaths": ["supabase/functions"],
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],
  "jest.virtualFolders": [
    {
      "name": "web",
      "rootPath": "apps/web",
      "jestCommandLine": "npm test -w chatly-web --"
    },
    {
      "name": "native",
      "rootPath": "apps/native",
      "jestCommandLine": "npm test -w chatly-native --"
    }
  ]
}
